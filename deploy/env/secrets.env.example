# =============================================================================
# HCI 智能排障平台 - 敏感配置模板（EXAMPLE 文件）
# =============================================================================
# 使用方式：
#   cp deploy/env/secrets.env.example deploy/env/secrets.env
#   编辑 secrets.env，填入真实值
#   secrets.env 已在 .gitignore 中，不提交 git
#
# 生产环境替代方案：
#   - 使用 Vault / AWS Secrets Manager / 阿里云 KMS 替代本文件
#   - 或通过 CI/CD pipeline 注入 helm install --set secrets.xxx=yyy
# =============================================================================

# ======================== 数据库 =============================================
# PostgreSQL 密码（首次部署后修改需同步更新 PVC 内数据库，否则服务无法连接）
HCI_SECRET_POSTGRES_PASSWORD="your-strong-password-here"

# ======================== OpenClaw 网关 Token ================================
# !! 关键配置 !!
# 此 Token 必须与以下两处完全一致，否则 conversation-service 调用返回 401：
#   1. 宿主机 ~/.openclaw/openclaw.json  ->  gateway.auth.token
#   2. K8s Secret OPENCLAW_GATEWAY_TOKEN  (本值)
# 修改步骤：
#   a) 修改本文件中的值
#   b) 同步修改宿主机 openclaw.json
#   c) helm upgrade 重新部署 + kubectl rollout restart deploy/conversation-service
HCI_SECRET_OPENCLAW_TOKEN="hci-dev-openclaw-token"

# ======================== 上游 AI 模型 API Key ================================
# ZAI (智谱) API Key，可在 https://open.bigmodel.cn/ 获取
# 留空则无法实际调用模型（对话返回 422）
HCI_SECRET_ZAI_API_KEY="your-zai-api-key-here"

# ======================== Grafana 管理员密码 ==================================
# 首次部署后如需修改，还需在 Grafana Pod 内执行：
#   grafana cli admin reset-admin-password 'new-password'
HCI_SECRET_GRAFANA_ADMIN_PASSWORD="your-grafana-password-here"
