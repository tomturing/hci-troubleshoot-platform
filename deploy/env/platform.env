# =============================================================================
# HCI 智能排障平台 - 统一配置变量文件（非敏感部分）
# =============================================================================
# 本文件为**所有环境共用的配置变量基准**，提交 git。
#
# 使用规则：
#   - 敏感值（密码/Token/API Key）放在 secrets.<variable> 中，不写在本文件
#   - 本文件中的变量被 Helm values.yaml / values.yaml overlay 引用
#   - 本地覆盖：COPY 本文件为 deploy/env/local.env，按需修改，该文件不提交 git
#
# 变量命名规范：
#   HCI_<SECTION>_<KEY>   如：HCI_POSTGRES_DB、HCI_DOMAIN
# =============================================================================

# ======================== 域名 / 接入层 ======================================
# 平台根域名（所有子域名的基础）
HCI_DOMAIN="hci.local"
# 各子域名完整地址（与 Helm ingress host 保持一致）
HCI_API_HOST="api.hci.local"
HCI_CUSTOMER_HOST="app.hci.local"
HCI_ADMIN_HOST="admin.hci.local"
HCI_GRAFANA_HOST="grafana.hci.local"
# Traefik Ingress entrypoint（本地 HTTP=web，生产 HTTPS=websecure）
# 生产环境：改为 websecure 并配置 TLS
HCI_INGRESS_ENTRYPOINT="web"

# ======================== Kubernetes =========================================
# 主业务命名空间
HCI_K8S_NAMESPACE="hci-troubleshoot"
# 可观测性命名空间
HCI_OBS_NAMESPACE="hci-observability"
# 容器 Runtime（影响 Promtail 配置）：docker | containerd
# 腾讯云/阿里云托管 K8s 默认 containerd；k3s 默认 containerd；裸机 Docker 环境 = docker
HCI_K8S_CONTAINER_RUNTIME="docker"
# 镜像仓库前缀（公司私仓时设为 "registry.example.com/"，本地留空）
HCI_IMAGE_REGISTRY=""
# 镜像拉取策略（本地：IfNotPresent；CI/CD：Always）
HCI_IMAGE_PULL_POLICY="IfNotPresent"

# ======================== PostgreSQL =========================================
HCI_POSTGRES_DB="hci_troubleshoot"
HCI_POSTGRES_USER="hci_admin"
# 存储大小（生产环境建议 >= 50Gi）
HCI_POSTGRES_STORAGE="5Gi"
HCI_POSTGRES_STORAGE_CLASS="local-path"

# ======================== Redis ==============================================
HCI_REDIS_URL="redis://redis:6379/0"
HCI_REDIS_STORAGE="1Gi"
HCI_REDIS_STORAGE_CLASS="local-path"

# ======================== 应用日志 / 链路 =====================================
HCI_LOG_LEVEL="INFO"
# OTel Collector 端点（Tempo gRPC）
HCI_OTEL_ENDPOINT="http://tempo.hci-observability.svc.cluster.local:4317"

# ======================== OpenClaw / AI 助手池 ================================
# !! 关键 !! openclawToken 必须与宿主机 ~/.openclaw/openclaw.json
#   gateway.auth.token 字段完全一致，否则 conversation-service 调用返回 401
# 默认开发 Token（生产环境通过 secrets 覆盖）：hci-dev-openclaw-token
HCI_OPENCLAW_TOKEN_NOTE="必须与宿主机 openclaw.json gateway.auth.token 保持一致"
# 助手暖池初始大小 / 上限
HCI_WARM_POOL_SIZE="2"
HCI_MAX_POOL_SIZE="10"
HCI_POD_IDLE_TIMEOUT="300"

# ======================== 可观测性 ==========================================
# Grafana 对外域名（与 HCI_GRAFANA_HOST 一致）
# 注意：Grafana 必须设置 GF_SERVER_DOMAIN + GF_SERVER_ROOT_URL
#       否则登录后会重定向到 localhost，导致无法访问
HCI_GRAFANA_DOMAIN="grafana.hci.local"
HCI_GRAFANA_ROOT_URL="http://grafana.hci.local/"
# Tempo 内存下限（低于 512Mi 会 OOMKilled）
HCI_TEMPO_MEMORY_LIMIT="512Mi"
