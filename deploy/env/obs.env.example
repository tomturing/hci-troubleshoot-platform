# 可观测性栈环境变量示例
# 复制为 obs.env 并填写真实值，不要提交到 git
# 生产环境必须修改 Grafana 默认密码

GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=your-strong-password-here

# Alertmanager 告警 Webhook
FEISHU_WEBHOOK_URL=
WECOM_WEBHOOK_URL=

# Grafana PostgreSQL 数据源密码（用于 Prompt 审计 Dashboard）
# 生产环境使用与 hci_troubleshoot 数据库相同的密码
GRAFANA_PG_PASSWORD=dev_password_123
