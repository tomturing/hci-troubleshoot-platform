[Unit]
Description=K8s CIDR and Docker routing bypass for Clash TUN
After=network.target

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/bin/bash -c 'ip rule add priority 100 to 10.42.0.0/16 lookup main 2>/dev/null || true; ip rule add priority 100 to 10.43.0.0/16 lookup main 2>/dev/null || true; ip rule add priority 100 from 10.42.0.0/16 lookup main 2>/dev/null || true; ip rule add priority 100 to 172.16.0.0/12 lookup main 2>/dev/null || true; ip rule add priority 100 from 172.16.0.0/12 lookup main 2>/dev/null || true'
ExecStop=/bin/bash -c 'ip rule del priority 100 to 10.42.0.0/16 lookup main 2>/dev/null || true; ip rule del priority 100 to 10.43.0.0/16 lookup main 2>/dev/null || true; ip rule del priority 100 from 10.42.0.0/16 lookup main 2>/dev/null || true; ip rule del priority 100 to 172.16.0.0/12 lookup main 2>/dev/null || true; ip rule del priority 100 from 172.16.0.0/12 lookup main 2>/dev/null || true'

[Install]
WantedBy=multi-user.target