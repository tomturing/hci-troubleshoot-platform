FROM python:3.12-slim

WORKDIR /app

COPY hci-troubleshoot-platform/adapters/cli_openai_adapter/server.py /app/server.py
COPY hci-troubleshoot-platform/adapters/cli_openai_adapter/bootstrap_nanobot.sh /app/bootstrap_nanobot.sh
COPY nanobot/ /src/nanobot/

RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir /src/nanobot && \
    chmod +x /app/bootstrap_nanobot.sh && \
    mkdir -p /root/.nanobot/workspace

ENV PYTHONUNBUFFERED=1 \
    ADAPTER_HOST=0.0.0.0 \
    ADAPTER_PORT=43102 \
    ADAPTER_MODEL=nanobot \
    ADAPTER_BEARER_TOKEN=nb_dev_token \
    ADAPTER_CMD_JSON='["/usr/local/bin/nanobot","agent","--message","{prompt}","--session","{session}","--no-markdown","--no-logs"]'

EXPOSE 43102
ENTRYPOINT ["/app/bootstrap_nanobot.sh"]
