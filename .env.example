# 数据库配置
DATABASE_URL=postgresql+asyncpg://hci_user:hci_password@localhost:5432/hci_troubleshoot
REDIS_URL=redis://localhost:6379/0

# 服务端口
API_GATEWAY_PORT=8000
CASE_SERVICE_PORT=8001
CONVERSATION_SERVICE_PORT=8002
SCHEDULER_SERVICE_PORT=8003

# OpenClaw配置
OPENCLAW_BASE_URL=http://localhost:8080
ZHIPU_API_KEY=your_zhipu_api_key_here

# K8s配置
K8S_NAMESPACE=hci-troubleshoot
OPENCLAW_IMAGE=openclaw:latest

# 日志级别
LOG_LEVEL=INFO
