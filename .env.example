# =============================================================================
# HCI 智能排障平台 - 环境变量模板
# =============================================================================
# 用法：
#   cp .env.example .env
#   然后按需修改敏感值（密码、Token、API Key 等）
#
# 变量加载优先级（高→低）：
#   1. docker-compose.yml 中的 environment 显式覆盖
#   2. .env 文件（被 docker-compose 自动读取）
#   3. backend/*/app/config.py 中的 pydantic-settings 默认值
#
# Tips：
#   - 生产环境请务必替换所有 *_PASSWORD / *_TOKEN / *_KEY
#   - K8s 部署时，敏感值走 Secret，非敏感值走 ConfigMap
# =============================================================================

# ======================== 数据库 (PostgreSQL 15) ============================
POSTGRES_DB=hci_troubleshoot
POSTGRES_USER=hci_admin
POSTGRES_PASSWORD=dev_password_123

# asyncpg 连接串（后端微服务使用）
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# ======================== 缓存 (Redis 7) ===================================
REDIS_URL=redis://redis:6379/0

# ======================== 后端微服务端口 ====================================
API_GATEWAY_PORT=8000
CASE_SERVICE_PORT=8001
CONVERSATION_SERVICE_PORT=8002
SCHEDULER_SERVICE_PORT=8003

# ======================== 服务间通信地址 ====================================
# Docker Compose / K8s 内部 DNS（api-gateway 调用下游服务使用）
CASE_SERVICE_URL=http://case-service:8001
CONVERSATION_SERVICE_URL=http://conversation-service:8002
SCHEDULER_SERVICE_URL=http://scheduler-service:8003

# ======================== OpenClaw / AI 模型 ================================
# OpenClaw 网关鉴权 Token
OPENCLAW_GATEWAY_TOKEN=hci-dev-openclaw-token
# OpenClaw API 地址（Docker 中通过 host.docker.internal 访问宿主机）
OPENCLAW_BASE_URL=http://host.docker.internal:18790

# OpenClaw 作为模型提供方（z.ai / GLM）时的 Key
# ZAI_API_KEY=
# Z_AI_API_KEY=

# ======================== 可观测性 (OpenTelemetry) ==========================
# OTLP gRPC 端点（Tempo 接收器）
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4317
LOG_LEVEL=INFO

# ======================== Grafana ==========================================
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# ======================== Scheduler / K8s ==================================
K8S_NAMESPACE=hci-troubleshoot
OPENCLAW_IMAGE=openclaw:latest
WARM_POOL_SIZE=2
MAX_POOL_SIZE=10
POD_IDLE_TIMEOUT=300

# ======================== 前端 =============================================
# Vite dev proxy 目标（仅本地开发使用）
VITE_API_BASE_URL=http://localhost:8000
