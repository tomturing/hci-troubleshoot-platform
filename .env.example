# =========================
# HCI 智能排障平台 - 环境变量模板
# 用法：
#   cp .env.example .env
#   然后按需补齐/覆盖
#
# 说明：
# - 本项目本地开发主要通过 deploy/docker/docker-compose.yml 启动（容器内互联）。
# - 所以下面的 DATABASE_URL/REDIS_URL 默认使用容器网络内的主机名（postgres/redis）。
# =========================

# ---------- Database / Redis (容器内默认) ----------
DATABASE_URL=postgresql+asyncpg://hci_user:hci_password@postgres:5432/hci_troubleshoot
REDIS_URL=redis://redis:6379/0

# ---------- 服务端口（宿主机暴露） ----------
API_GATEWAY_PORT=8000
CASE_SERVICE_PORT=8001
CONVERSATION_SERVICE_PORT=8002
SCHEDULER_SERVICE_PORT=8003

# ---------- OpenClaw（真实服务） ----------
# OpenClaw 网关鉴权 Token（Conversation Service 会用它访问 OpenClaw /v1/chat/completions）
OPENCLAW_GATEWAY_TOKEN=hci-dev-openclaw-token

# OpenClaw 作为模型提供方（z.ai / GLM）时的 Key（可二选一）
# ZAI_API_KEY=
# Z_AI_API_KEY=

# ---------- Observability (Tempo OTLP) ----------
# shared/utils/otel.py 默认 endpoint=tempo:4317；如需覆盖可设置：
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4317

# ---------- Logging ----------
LOG_LEVEL=INFO

# ---------- Kubernetes (可选) ----------
K8S_NAMESPACE=hci-troubleshoot
