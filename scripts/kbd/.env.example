# KBD 知识生产管道配置示例
# 使用：cp .env.example .env
# 危险：.env 含 Cookie 和 API Key，禁止提交到 Git

# ── 认证（必填）─────────────────────────────────────────────────────────────
# 从浏览器 DevTools → Network → 请求详情 → Request Headers → Cookie 复制
# 示例：PHPSESSID=abc123; _pk_id.181.9ff8=xxx; HMACCOUNT=xxx
SANGFOR_COOKIE=PHPSESSID=your_session_id; _pk_id.181.9ff8=xxx; visitor_id=xxx; HMACCOUNT=xxx

# ── 抓取配置（可选，按需调整）────────────────────────────────────────────────
SANGFOR_API_BASE=https://support.sangfor.com.cn
# 请求间隔（秒），建议 >= 0.8 以避免触发限流
SANGFOR_REQUEST_DELAY=0.8
SANGFOR_TIMEOUT=30.0
SANGFOR_MAX_RETRIES=4

# ── 文件路径（可选，默认值已匹配项目目录结构）──────────────────────────────────
# Excel 文件路径（相对项目根目录）
EXCEL_FILE=案例生产详细数据24-26.xlsx
# 图片下载目录
IMAGES_DIR=data-pipeline/images
# category_baseline.yaml 路径
CATEGORY_BASELINE=data-pipeline/config/category_baseline.yaml

# ── 数据库（必填）────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://hci_user:hci_pass@localhost:5432/hci_db

# ── LLM（必填）───────────────────────────────────────────────────────────────
ZAI_API_KEY=your_api_key_here
ZAI_BASE_URL=https://api.z.ai/v1

# Vision 模型（用于图片语义化，需支持 image_url 输入）
VISION_MODEL=gpt-4o

# 分类模型（用于 AI 分类，文本推理即可）
CLASSIFY_MODEL=gpt-4o-mini

# ── 管道行为（可选）──────────────────────────────────────────────────────────
# Vision 并发数（同时处理的图片数量）
VISION_CONCURRENCY=3
# 最低图片文件大小（字节），小于此值视为无效图片（icon/占位图）
MIN_IMAGE_SIZE=2048
# AI 分类置信度阈值：低于此值时标记"需人工重新分类"
MIN_CLASSIFY_CONFIDENCE=0.5

# ── kb-service API（必填，数据管道调用）────────────────────────────────────────
# kb-service 内部 API 地址
KB_SERVICE_URL=http://localhost:8004
# 内部服务认证 Token（与 kb-service 配置的 INTERNAL_API_TOKEN 一致）
INTERNAL_API_TOKEN=hci-dev-internal-token
# API 请求超时（秒）
API_TIMEOUT=30.0
# API 最大重试次数
API_MAX_RETRIES=3
